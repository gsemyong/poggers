{
  "name": "@poggers/kit",
  "version": "0.0.0",
  "description": "A portable TypeScript product language for programs, capabilities, and user interfaces.",
  "bin": {
    "poggers": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "src/application.ts",
    "src/cli.ts",
    "src/compiler/backend/development.ts",
    "src/compiler/backend/production.ts",
    "src/compiler/frontend.ts",
    "src/compiler/ir.ts",
    "src/execution.ts",
    "src/index.ts",
    "src/ui/component.ts",
    "src/ui/index.ts",
    "src/ui/platform.ts",
    "src/ui/presentation.ts",
    "src/ui/web/backend.ts",
    "src/ui/web/index.ts",
    "src/ui/web/jsx/development.ts",
    "src/ui/web/jsx/runtime.ts",
    "src/ui/web/jsx/types.ts",
    "src/ui/web/platform.ts",
    "src/ui/web/presentation/font.ts",
    "src/ui/web/presentation/index.ts",
    "src/ui/web/presentation/language.ts",
    "src/ui/web/presentation/motion.ts",
    "src/ui/web/presentation/runtime.ts",
    "src/ui/web/presentation/style.ts",
    "src/ui/web/structure/compiler.ts",
    "src/ui/web/structure/interaction.ts",
    "src/ui/web/structure/language.ts",
    "src/ui/web/structure/runtime.ts",
    "src/ui/web/structure/scene.ts",
    "template",
    "template/.gitignore",
    "tsconfig.json"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "poggers-source": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./jsx-dev-runtime": {
      "poggers-source": "./src/ui/web/jsx/development.ts",
      "types": "./dist/src/ui/web/jsx/development.d.ts",
      "default": "./dist/src/ui/web/jsx/development.js"
    },
    "./jsx-runtime": {
      "poggers-source": "./src/ui/web/jsx/runtime.ts",
      "types": "./dist/src/ui/web/jsx/runtime.d.ts",
      "default": "./dist/src/ui/web/jsx/runtime.js"
    },
    "./ui": {
      "poggers-source": "./src/ui/index.ts",
      "types": "./dist/src/ui/index.d.ts",
      "default": "./dist/src/ui/index.js"
    },
    "./presentation": {
      "poggers-source": "./src/ui/presentation.ts",
      "types": "./dist/src/ui/presentation.d.ts",
      "default": "./dist/src/ui/presentation.js"
    },
    "./web": {
      "poggers-source": "./src/ui/web/index.ts",
      "types": "./dist/src/ui/web/index.d.ts",
      "default": "./dist/src/ui/web/index.js"
    },
    "./web/presentation": {
      "poggers-source": "./src/ui/web/presentation/index.ts",
      "types": "./dist/src/ui/web/presentation/index.d.ts",
      "default": "./dist/src/ui/web/presentation/index.js"
    },
    "./tsconfig": "./tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "nub scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint src scripts",
    "test": "vitest run src",
    "check": "nub run typecheck && nub run lint && nub run fmt:check && nub run test"
  },
  "dependencies": {
    "@tanstack/virtual-core": "^3.17.4",
    "@typescript/typescript6": "^6.0.2",
    "alien-signals": "^3.2.1",
    "animejs": "^4.5.0",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "nub@0.4.13"
}
