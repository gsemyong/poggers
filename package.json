{
  "name": "@poggers/kit",
  "version": "0.0.0",
  "description": "A portable TypeScript product language for programs, dependencies, and user interfaces.",
  "bin": {
    "poggers": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "examples/basic",
    "examples/basic/.gitignore",
    "tsconfig.json"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "poggers-source": "./dist/source/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./jsx-dev-runtime": {
      "poggers-source": "./dist/source/jsx/development.ts",
      "types": "./dist/src/jsx/development.d.ts",
      "default": "./dist/src/jsx/development.js"
    },
    "./jsx-runtime": {
      "poggers-source": "./dist/source/jsx/runtime.ts",
      "types": "./dist/src/jsx/runtime.d.ts",
      "default": "./dist/src/jsx/runtime.js"
    },
    "./web": {
      "poggers-source": "./dist/source/platforms/web/platform.ts",
      "types": "./dist/src/platforms/web/platform.d.ts",
      "default": "./dist/src/platforms/web/platform.js"
    },
    "./adapters/web": {
      "poggers-source": "./dist/source/adapters/web/adapter.ts",
      "types": "./dist/src/adapters/web/adapter.d.ts",
      "default": "./dist/src/adapters/web/adapter.js"
    },
    "./server": {
      "poggers-source": "./dist/source/platforms/server/platform.ts",
      "types": "./dist/src/platforms/server/platform.d.ts",
      "default": "./dist/src/platforms/server/platform.js"
    },
    "./testing": {
      "poggers-source": "./dist/source/testing.ts",
      "types": "./dist/src/testing.d.ts",
      "default": "./dist/src/testing.js"
    },
    "./adapter": {
      "poggers-source": "./dist/source/contracts/platform.ts",
      "types": "./dist/src/contracts/platform.d.ts",
      "default": "./dist/src/contracts/platform.js"
    },
    "./adapters/server": {
      "poggers-source": "./dist/source/adapters/server/adapter.ts",
      "types": "./dist/src/adapters/server/adapter.d.ts",
      "default": "./dist/src/adapters/server/adapter.js"
    },
    "./cli": {
      "poggers-source": "./dist/source/cli.ts",
      "types": "./dist/src/cli.d.ts",
      "default": "./dist/src/cli.js"
    },
    "./tsconfig": "./tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "nub scripts/build.ts",
    "benchmark": "nub scripts/benchmark.ts",
    "dev:crud": "nub src/cli.ts dev --dir examples/authenticated-crud",
    "dev:example": "nub src/cli.ts dev --dir playground",
    "typecheck": "tsc --noEmit && tsc -p src/adapters/web/fixtures/request-render/tsconfig.json && tsc -p examples/basic/tsconfig.json && tsc -p examples/authenticated-crud/tsconfig.json && tsc -p playground/tsconfig.json",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --disable-nested-config src scripts examples playground vitest.config.ts",
    "test": "nub run build && vitest run && cargo test --manifest-path src/adapters/server/production/Cargo.toml --workspace",
    "check": "nub run typecheck && nub run lint && nub run fmt:check && nub run test"
  },
  "dependencies": {
    "@nats-io/jetstream": "3.4.0",
    "@nats-io/transport-node": "3.4.0",
    "@tanstack/virtual-core": "^3.17.6",
    "@typescript/typescript6": "^6.0.2",
    "alien-signals": "^3.2.1",
    "better-auth": "^1.6.24",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "fast-check": "^4.9.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "nub@0.4.13"
}
