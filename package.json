{
  "name": "poggers-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "nub run -r --if-present typecheck",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint .",
    "test": "nub run -r --if-present test",
    "build": "nub run -r --if-present build",
    "dev:chat": "nub run --filter @poggers/chat dev",
    "dev:visual-lab": "nub run --filter @poggers/visual-lab dev",
    "check": "nub run typecheck && nub run lint && nub run fmt:check && nub run test"
  },
  "devDependencies": {
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.4.13",
      "onFail": "warn"
    }
  },
  "packageManager": "nub@0.4.13"
}
