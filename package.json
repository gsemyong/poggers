{
  "name": "@poggers/kit",
  "version": "0.0.0",
  "description": "A portable TypeScript product language for programs, capabilities, and user interfaces.",
  "bin": {
    "poggers": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.ts",
    "!src/**/*.typecheck.ts",
    "!src/**/*.typecheck.tsx",
    "template",
    "template/.gitignore",
    "tsconfig.json"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "poggers-source": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./jsx-dev-runtime": {
      "poggers-source": "./src/core/jsx/development.ts",
      "types": "./dist/src/core/jsx/development.d.ts",
      "default": "./dist/src/core/jsx/development.js"
    },
    "./jsx-runtime": {
      "poggers-source": "./src/core/jsx/runtime.ts",
      "types": "./dist/src/core/jsx/runtime.d.ts",
      "default": "./dist/src/core/jsx/runtime.js"
    },
    "./web": {
      "poggers-source": "./src/adapters/web/public.ts",
      "types": "./dist/src/adapters/web/public.d.ts",
      "default": "./dist/src/adapters/web/public.js"
    },
    "./adapters/web": {
      "poggers-source": "./src/adapters/web/index.ts",
      "types": "./dist/src/adapters/web/index.d.ts",
      "default": "./dist/src/adapters/web/index.js"
    },
    "./web/presentation": {
      "poggers-source": "./src/adapters/web/presentation/index.ts",
      "types": "./dist/src/adapters/web/presentation/index.d.ts",
      "default": "./dist/src/adapters/web/presentation/index.js"
    },
    "./tsconfig": "./tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "nub scripts/build.ts",
    "benchmark": "nub scripts/benchmark.ts",
    "dev:example": "nub src/cli.ts dev --dir examples/web-presentation",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint src scripts examples vitest.config.ts",
    "test": "vitest run",
    "check": "nub run typecheck && nub run lint && nub run fmt:check && nub run test"
  },
  "dependencies": {
    "@tanstack/virtual-core": "^3.17.4",
    "@typescript/typescript6": "^6.0.2",
    "alien-signals": "^3.2.1",
    "animejs": "^4.5.0",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "fast-check": "^4.9.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "nub@0.4.13"
}
