{
  "name": "poggers-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "turbo run typecheck",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint .",
    "test": "turbo run test",
    "build": "turbo run build",
    "dev:chat": "bun run --filter @poggers/chat dev",
    "dev:data-flow": "bun run --filter @poggers/data-flow dev",
    "dev:site": "bun run --filter @poggers/site dev",
    "dev:visual-lab": "bun run --filter @poggers/visual-lab dev",
    "check": "bun run typecheck && bun run lint && bun run fmt:check && bun run test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.14"
}
