{
  "compilerOptions": {
    "lib": ["ES2024", "ESNext.Disposable", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@poggers/kit",
    "allowImportingTsExtensions": true,
    "types": [],
    "moduleResolution": "bundler",
    "customConditions": ["poggers-source"],
    "paths": {
      "@/*": ["./src/*"],
      "src/*": ["${configDir}/src/*"]
    },
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": [
    "${configDir}/src/**/*.ts",
    "${configDir}/src/**/*.tsx",
    "${configDir}/src/**/*.d.ts",
    "${configDir}/scripts/**/*.ts"
  ]
}
