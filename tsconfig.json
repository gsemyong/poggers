{
  "compilerOptions": {
    "lib": ["ES2024", "ESNext.Disposable", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@poggers/kit",
    "allowImportingTsExtensions": true,
    "types": [],
    "moduleResolution": "bundler",
    "customConditions": ["poggers-source"],
    "paths": {
      "@/*": ["./src/*"],
      "@poggers/kit": ["./src/index.ts", "./dist/source/index.ts"],
      "@poggers/kit/jsx-dev-runtime": [
        "./src/jsx/development.ts",
        "./dist/source/jsx/development.ts"
      ],
      "@poggers/kit/jsx-runtime": ["./src/jsx/runtime.ts", "./dist/source/jsx/runtime.ts"],
      "@poggers/kit/web": [
        "./src/platforms/web/platform.ts",
        "./dist/source/platforms/web/platform.ts"
      ],
      "@poggers/kit/adapters/web": [
        "./src/adapters/web/adapter.ts",
        "./dist/source/adapters/web/adapter.ts"
      ],
      "@poggers/kit/server": [
        "./src/platforms/server/platform.ts",
        "./dist/source/platforms/server/platform.ts"
      ],
      "@poggers/kit/testing": ["./src/testing.ts", "./dist/src/testing.d.ts"],
      "@poggers/kit/adapter": [
        "./src/contracts/platform.ts",
        "./dist/source/contracts/platform.ts"
      ],
      "@poggers/kit/adapters/server": [
        "./src/adapters/server/adapter.ts",
        "./dist/source/adapters/server/adapter.ts"
      ]
    },
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": [
    "${configDir}/src/**/*.ts",
    "${configDir}/src/**/*.tsx",
    "${configDir}/src/**/*.d.ts",
    "${configDir}/scripts/**/*.ts"
  ]
}
