{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "import/no-cycle": "error",
    "no-duplicate-imports": "error",
    "typescript/consistent-type-imports": "error",
    "typescript/no-explicit-any": "error",
    "unicorn/filename-case": "error"
  },
  "overrides": [
    {
      "files": ["src/**/*.ts", "src/**/*.tsx"],
      "rules": {
        "no-restricted-imports": ["error", { "patterns": ["./**", "../**"] }]
      }
    },
    {
      "files": [
        "src/core/application.ts",
        "src/core/component.ts",
        "src/core/development.ts",
        "src/core/ui.ts",
        "src/core/presentation.ts",
        "src/core/process.ts",
        "src/core/compiler/ir.ts",
        "src/core/compiler/source.ts",
        "src/core/jsx/development.ts",
        "src/core/jsx/runtime.ts",
        "src/core/capability.ts",
        "src/contracts/platform.ts"
      ],
      "rules": {
        "no-restricted-imports": ["error", { "patterns": ["./**", "../**", "**/adapters/**"] }]
      }
    }
  ],
  "options": {
    "reportUnusedDisableDirectives": "error",
    "denyWarnings": true
  }
}
