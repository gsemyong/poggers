{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "import/no-cycle": "error",
    "no-duplicate-imports": "error",
    "typescript/consistent-type-imports": "error",
    "typescript/no-explicit-any": "error",
    "unicorn/filename-case": "error"
  },
  "overrides": [
    {
      "files": ["src/**/*.ts", "src/**/*.tsx"],
      "rules": {
        "no-restricted-imports": ["error", { "patterns": ["./**", "../**"] }]
      }
    },
    {
      "files": ["src/core/**/*.ts", "src/contracts/**/*.ts"],
      "rules": {
        "no-restricted-imports": ["error", { "patterns": ["./**", "../**", "**/adapters/**"] }]
      }
    },
    {
      "files": ["src/platforms/**/*.ts", "src/platforms/**/*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "./**",
              "../**",
              "@/adapters/**",
              "@/compiler/**",
              "@/contracts/**",
              "@/features/**",
              "@/runtime/**"
            ]
          }
        ]
      }
    },
    {
      "files": ["src/adapters/server/**/*.ts"],
      "rules": {
        "no-restricted-imports": ["error", { "patterns": ["./**", "../**", "@/adapters/web/**"] }]
      }
    },
    {
      "files": ["src/adapters/web/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          { "patterns": ["./**", "../**", "@/adapters/server/**"] }
        ]
      }
    }
  ],
  "options": {
    "reportUnusedDisableDirectives": "error",
    "denyWarnings": true
  }
}
