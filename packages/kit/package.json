{
  "name": "@poggers/kit",
  "version": "0.0.0",
  "description": "A batteries-included TypeScript framework for local-first applications.",
  "bin": {
    "poggers": "./src/tooling/cli.ts"
  },
  "files": [
    "src",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*.typecheck.ts",
    "!src/**/*.typecheck.tsx",
    "dist",
    "tsconfig.app.json"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "imports": {
    "#features/*": {
      "poggers-source": "./src/features/*.ts",
      "types": "./dist/src/features/*.d.ts",
      "bun": "./src/features/*.ts",
      "default": "./dist/src/features/*.js"
    },
    "#host/*": {
      "poggers-source": "./src/host/*.ts",
      "types": "./dist/src/host/*.d.ts",
      "bun": "./src/host/*.ts",
      "default": "./dist/src/host/*.js"
    },
    "#kernel/*": {
      "poggers-source": "./src/kernel/*.ts",
      "types": "./dist/src/kernel/*.d.ts",
      "bun": "./src/kernel/*.ts",
      "default": "./dist/src/kernel/*.js"
    },
    "#substrate/*": {
      "poggers-source": "./src/substrate/*.ts",
      "types": "./dist/src/substrate/*.d.ts",
      "bun": "./src/substrate/*.ts",
      "default": "./dist/src/substrate/*.js"
    },
    "#testing/*": {
      "poggers-source": "./src/testing/*.ts",
      "types": "./dist/src/testing/*.d.ts",
      "bun": "./src/testing/*.ts",
      "default": "./dist/src/testing/*.js"
    },
    "#tooling/*": {
      "poggers-source": "./src/tooling/*.ts",
      "types": "./dist/src/tooling/*.d.ts",
      "bun": "./src/tooling/*.ts",
      "default": "./dist/src/tooling/*.js"
    },
    "#ui/*": {
      "poggers-source": "./src/ui/*.ts",
      "types": "./dist/src/ui/*.d.ts",
      "bun": "./src/ui/*.ts",
      "default": "./dist/src/ui/*.js"
    }
  },
  "exports": {
    ".": {
      "poggers-source": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./jsx-dev-runtime": {
      "poggers-source": "./src/ui/web/jsx-dev-runtime.ts",
      "types": "./dist/src/ui/web/jsx-dev-runtime.d.ts",
      "default": "./dist/src/ui/web/jsx-dev-runtime.js"
    },
    "./jsx-runtime": {
      "poggers-source": "./src/ui/web/jsx-runtime.ts",
      "types": "./dist/src/ui/web/jsx-runtime.d.ts",
      "default": "./dist/src/ui/web/jsx-runtime.js"
    },
    "./ui": {
      "poggers-source": "./src/ui/index.ts",
      "types": "./dist/src/ui/index.d.ts",
      "default": "./dist/src/ui/index.js"
    },
    "./preset": {
      "poggers-source": "./src/ui/preset.ts",
      "types": "./dist/src/ui/preset.d.ts",
      "default": "./dist/src/ui/preset.js"
    },
    "./testing": {
      "poggers-source": "./src/testing/application.ts",
      "types": "./dist/src/testing/application.d.ts",
      "default": "./dist/src/testing/application.js"
    },
    "./testing/substrate": {
      "poggers-source": "./src/testing/substrate.ts",
      "types": "./dist/src/testing/substrate.d.ts",
      "default": "./dist/src/testing/substrate.js"
    },
    "./host/browser": {
      "poggers-source": "./src/host/browser.ts",
      "types": "./dist/src/host/browser.d.ts",
      "default": "./dist/src/host/browser.js"
    },
    "./host/server": {
      "poggers-source": "./src/host/server.ts",
      "types": "./dist/src/host/server.d.ts",
      "default": "./dist/src/host/server.js"
    },
    "./tsconfig": "./tsconfig.app.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src scripts",
    "test": "bun test src"
  },
  "dependencies": {
    "@marcbachmann/cel-js": "8.0.0",
    "@stylexjs/stylex": "^0.19.0",
    "@stylexjs/unplugin": "^0.19.0",
    "@tanstack/virtual-core": "^3.17.3",
    "@types/bun": "^1.3.14",
    "@typescript/typescript6": "^6.0.2",
    "alien-signals": "^3.2.1",
    "animejs": "^4.5.0",
    "croner": "10.0.1",
    "typescript": "^7.0.2",
    "unplugin": "^2.3.11",
    "xstate": "5.32.4"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0"
  }
}
