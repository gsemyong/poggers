{
  "name": "@poggers/kit",
  "version": "0.0.0",
  "description": "A tiny event-sourced full-stack kit for building applications.",
  "bin": {
    "poggers": "./src/cli.ts"
  },
  "files": [
    "src",
    "types",
    "tsconfig.app.json",
    "tsconfig.json"
  ],
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./types/jsx-dev-runtime.d.ts",
      "default": "./src/jsx-dev-runtime.ts"
    },
    "./jsx-runtime": {
      "types": "./types/jsx-runtime.d.ts",
      "default": "./src/jsx-runtime.ts"
    },
    "./program": {
      "types": "./types/program.d.ts",
      "default": "./src/program.ts"
    },
    "./storage": {
      "types": "./types/storage.d.ts",
      "default": "./src/storage.ts"
    },
    "./ui": {
      "types": "./types/ui.d.ts",
      "default": "./src/ui.ts"
    },
    "./style": {
      "types": "./types/style.d.ts",
      "default": "./src/style.ts"
    },
    "./worker": {
      "types": "./types/worker.d.ts",
      "default": "./src/worker.ts"
    },
    "./testing": {
      "types": "./types/testing.d.ts",
      "default": "./src/testing.ts"
    },
    "./app": {
      "types": "./types/runtime.d.ts",
      "default": "./src/runtime.ts"
    },
    "./tsconfig": "./tsconfig.app.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests",
    "test": "bun test tests",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "alien-signals": "^3.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "typescript": "7.0.1-rc"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
