{
  "name": "@poggers/kit",
  "version": "0.0.0",
  "description": "A portable TypeScript product language for programs, capabilities, and user interfaces.",
  "bin": {
    "poggers": "./dist/src/tooling/cli.js"
  },
  "files": [
    "src/application.ts",
    "src/compiler/backend.node.ts",
    "src/compiler/backend.rust.ts",
    "src/compiler/frontend.ts",
    "src/compiler/hot.ts",
    "src/compiler/ir.ts",
    "src/index.ts",
    "src/runtime.ts",
    "src/tooling/application.ts",
    "src/tooling/cli.ts",
    "src/tooling/create.ts",
    "src/ui/compiler/application.ts",
    "src/ui/component.ts",
    "src/ui/index.ts",
    "src/ui/presentation.ts",
    "src/ui/platform.ts",
    "src/ui/adapters/web/adapter.ts",
    "src/ui/adapters/web/drag.anime.ts",
    "src/ui/adapters/web/drag.ts",
    "src/ui/adapters/web/interaction.ts",
    "src/ui/adapters/web/jsx-dev-runtime.ts",
    "src/ui/adapters/web/jsx-runtime.ts",
    "src/ui/adapters/web/jsx-types.ts",
    "src/ui/adapters/web/motion.ts",
    "src/ui/adapters/web/presentation.ts",
    "src/ui/adapters/web/presentation/language.ts",
    "src/ui/adapters/web/platform.ts",
    "src/ui/adapters/web/presentation/adapter.ts",
    "src/ui/adapters/web/presentation/font.ts",
    "src/ui/adapters/web/presentation/style.ts",
    "src/ui/adapters/web/runtime.ts",
    "src/ui/adapters/web/scene.ts",
    "src/ui/adapters/web/structure.ts",
    "template",
    "dist",
    "tsconfig.app.json"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "imports": {
    "#ui/*": {
      "poggers-source": "./src/ui/*.ts",
      "types": "./dist/src/ui/*.d.ts",
      "default": "./dist/src/ui/*.js"
    }
  },
  "exports": {
    ".": {
      "poggers-source": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./jsx-dev-runtime": {
      "poggers-source": "./src/ui/adapters/web/jsx-dev-runtime.ts",
      "types": "./dist/src/ui/adapters/web/jsx-dev-runtime.d.ts",
      "default": "./dist/src/ui/adapters/web/jsx-dev-runtime.js"
    },
    "./jsx-runtime": {
      "poggers-source": "./src/ui/adapters/web/jsx-runtime.ts",
      "types": "./dist/src/ui/adapters/web/jsx-runtime.d.ts",
      "default": "./dist/src/ui/adapters/web/jsx-runtime.js"
    },
    "./ui": {
      "poggers-source": "./src/ui/index.ts",
      "types": "./dist/src/ui/index.d.ts",
      "default": "./dist/src/ui/index.js"
    },
    "./presentation": {
      "poggers-source": "./src/ui/presentation.ts",
      "types": "./dist/src/ui/presentation.d.ts",
      "default": "./dist/src/ui/presentation.js"
    },
    "./presentation/web": {
      "poggers-source": "./src/ui/adapters/web/presentation.ts",
      "types": "./dist/src/ui/adapters/web/presentation.d.ts",
      "default": "./dist/src/ui/adapters/web/presentation.js"
    },
    "./tsconfig": "./tsconfig.app.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "nub scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src scripts",
    "test": "vitest run src"
  },
  "dependencies": {
    "@tanstack/virtual-core": "^3.17.3",
    "@types/node": "^24.13.3",
    "@typescript/typescript6": "^6.0.2",
    "alien-signals": "^3.2.1",
    "animejs": "^4.5.0",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
