{
  "name": "@poggers/kit",
  "version": "0.0.0",
  "description": "A tiny event-sourced full-stack kit for building applications.",
  "bin": {
    "poggers": "./src/infra/cli.ts"
  },
  "files": [
    "app-types",
    "src/app.ts",
    "src/index.ts",
    "src/jsx-dev-runtime.ts",
    "src/jsx-runtime.ts",
    "src/program.ts",
    "src/react.ts",
    "src/style.ts",
    "src/testing.ts",
    "src/ui.ts",
    "src/worker.ts",
    "types",
    "tsconfig.app.json",
    "src/infra",
    "!src/infra/**/*.spec.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./types/jsx-dev-runtime.d.ts",
      "default": "./src/jsx-dev-runtime.ts"
    },
    "./jsx-runtime": {
      "types": "./types/jsx-runtime.d.ts",
      "default": "./src/jsx-runtime.ts"
    },
    "./react": "./src/react.ts",
    "./program": "./src/program.ts",
    "./ui": {
      "types": "./types/ui.d.ts",
      "default": "./src/ui.ts"
    },
    "./style": {
      "types": "./types/style.d.ts",
      "default": "./src/style.ts"
    },
    "./worker": "./src/worker.ts",
    "./testing": "./src/testing.ts",
    "./app": {
      "types": "./types/app.d.ts",
      "default": "./src/app.ts"
    },
    "./app-types": "./app-types/index.d.ts",
    "./tsconfig": "./tsconfig.app.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "bun test src/infra",
    "pack:dry": "npm pack --dry-run --json"
  },
  "dependencies": {
    "alien-signals": "^3.2.1",
    "lmdb": "^3.5.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "7.0.1-rc"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
