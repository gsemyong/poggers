{
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@poggers/kit",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "types": ["@poggers/kit/globals"],
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@poggers/app": ["${configDir}/.poggers/types/app.d.ts"],
      "app": ["${configDir}/src/app.ts"],
      "deps": ["${configDir}/src/deps.ts"],
      "types": ["${configDir}/src/types.ts"],
      "src/*": ["${configDir}/src/*"],
      "ui/*": ["${configDir}/src/ui/*"]
    }
  },
  "include": [
    "${configDir}/src/**/*.ts",
    "${configDir}/src/**/*.tsx",
    "${configDir}/src/**/*.d.ts"
  ],
  "exclude": ["${configDir}/src/deps.ts", "${configDir}/src/migrations/**/*.ts"]
}
