{
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@poggers/kit",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "types": ["bun"],
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@poggers/app": [
        "${configDir}/.app/types/@poggers/app/index.d.ts",
        "${configDir}/.app/types/@poggers/app/index.tsx",
        "${configDir}/node_modules/@poggers/kit/app-types/index.d.ts",
        "${configDir}/../../packages/kit/app-types/index.d.ts",
        "./app-types/index.d.ts"
      ]
    }
  },
  "include": [
    "${configDir}/src/**/*.ts",
    "${configDir}/src/**/*.tsx",
    "${configDir}/.app/types/**/*.d.ts"
  ]
}
