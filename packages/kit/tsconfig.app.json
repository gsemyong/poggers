{
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@poggers/kit",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "types": ["@poggers/kit/globals"],
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "src/*": ["${configDir}/src/*"],
      "ai": [
        "${configDir}/../../packages/kit/types/vendor/ai.d.ts",
        "${configDir}/node_modules/@poggers/kit/types/vendor/ai.d.ts",
        "${configDir}/../node_modules/@poggers/kit/types/vendor/ai.d.ts",
        "${configDir}/../../node_modules/@poggers/kit/types/vendor/ai.d.ts"
      ],
      "zod/v4-mini": [
        "${configDir}/../../packages/kit/types/vendor/zod-v4-mini.d.ts",
        "${configDir}/node_modules/@poggers/kit/types/vendor/zod-v4-mini.d.ts",
        "${configDir}/../node_modules/@poggers/kit/types/vendor/zod-v4-mini.d.ts",
        "${configDir}/../../node_modules/@poggers/kit/types/vendor/zod-v4-mini.d.ts"
      ]
    }
  },
  "include": [
    "${configDir}/src/**/*.ts",
    "${configDir}/src/**/*.tsx",
    "${configDir}/src/**/*.d.ts"
  ],
  "exclude": ["${configDir}/src/migrations/**/*.ts"]
}
