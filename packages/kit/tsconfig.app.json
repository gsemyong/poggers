{
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@poggers/kit",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "types": ["bun"],
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@poggers/app": ["${configDir}/src/poggers-app.d.ts"]
    }
  },
  "include": ["${configDir}/src/**/*.ts", "${configDir}/src/**/*.tsx", "${configDir}/src/**/*.d.ts"]
}
